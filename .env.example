# Copy to .env and fill in. Never commit .env.

# --- SEC EDGAR -------------------------------------------------------------
# Required by ingestion/fetch_edgar.py. SEC fair-access policy requires a
# descriptive User-Agent identifying you with contact info:
#   https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT="Provenance research project you@example.com"

# --- Postgres (defaults match infra/docker-compose.yml) ---------------------
POSTGRES_USER=provenance
POSTGRES_PASSWORD=provenance
POSTGRES_DB=provenance
POSTGRES_HOST=localhost
# host port for the dockerized Postgres (container-internal port is 5432);
# 5433 avoids clashing with other local Postgres instances
POSTGRES_PORT=5433
# Or set a full connection string instead of the pieces above:
# PROVENANCE_DB_URL=postgresql://provenance:provenance@localhost:5433/provenance
